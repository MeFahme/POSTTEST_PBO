<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #FDF5E6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mybakery.gui.controller.DashboardController">
    <children>
        <VBox prefHeight="500.0" prefWidth="180.0" style="-fx-background-color: #5D4037; -fx-spacing: 15; -fx-padding: 20;">
            <children>
                <Label text="BakeSmart" textFill="#FFECB3">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Separator opacity="0.3" />

                <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #FFECB3; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="Dashboard">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>

                <Button maxWidth="Infinity" onAction="#menuKelolaProduk" style="-fx-background-color: transparent; -fx-text-fill: #FFECB3; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="Kelola Produk" />

                <Button maxWidth="Infinity" onAction="#menuTransaksi" style="-fx-background-color: transparent; -fx-text-fill: #FFECB3; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="Transaksi" />

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #D32F2F; -fx-background-radius: 5; -fx-cursor: hand;" text="Logout" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </VBox>

        <AnchorPane layoutX="180.0" prefHeight="500.0" prefWidth="620.0">
            <children>
                <Label fx:id="lblWelcome" layoutX="25.0" layoutY="25.0" text="Selamat Datang, User" textFill="#5D4037">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>

                <Label layoutX="25.0" layoutY="65.0" text="Daftar Inventaris Roti" textFill="#8D6E63">
                    <font><Font name="System Italic" size="14.0" /></font>
                </Label>

                <TableView fx:id="tableProduk" layoutX="25.0" layoutY="100.0" prefHeight="365.0" prefWidth="570.0" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #D7CCC8;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80" text="ID Produk" />
                        <TableColumn fx:id="colNama" prefWidth="240" text="Nama Roti" />
                        <TableColumn fx:id="colHarga" prefWidth="140" text="Harga (Rp)" />
                        <TableColumn fx:id="colStok" prefWidth="105" text="Stok" />
                    </columns>
                </TableView>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>