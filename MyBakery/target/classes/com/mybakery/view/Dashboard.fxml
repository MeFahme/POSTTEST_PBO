<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mybakery.gui.controller.DashboardController">
    <children>
        <VBox prefHeight="500.0" prefWidth="180.0" style="-fx-background-color: #2c3e50; -fx-spacing: 10; -fx-padding: 20;">
            <children>
                <Label text="BakeSmart" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Separator />
                <Button maxWidth="Infinity" text="Dashboard" />
                <Button maxWidth="Infinity" onAction="#menuKelolaProduk" text="Kelola Produk" />
                <Button maxWidth="Infinity" onAction="#menuTransaksi" text="Transaksi" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #e74c3c;" text="Logout" textFill="WHITE" />
            </children>
        </VBox>

        <AnchorPane layoutX="180.0" prefHeight="500.0" prefWidth="620.0">
            <children>
                <Label fx:id="lblWelcome" layoutX="20.0" layoutY="20.0" text="Selamat Datang, User">
                    <font><Font size="18.0" /></font>
                </Label>
                <TableView fx:id="tableProduk" layoutX="20.0" layoutY="100.0" prefHeight="350.0" prefWidth="580.0">
                    <columns>
                        <TableColumn fx:id="colId" text="ID Produk" prefWidth="80" />
                        <TableColumn fx:id="colNama" text="Nama Roti" prefWidth="250" />
                        <TableColumn fx:id="colHarga" text="Harga Dasar" prefWidth="150" />
                        <TableColumn fx:id="colStok" text="Stok" prefWidth="98" />
                    </columns>
                </TableView>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>